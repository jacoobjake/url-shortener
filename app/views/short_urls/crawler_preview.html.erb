<% metadata = local_assigns[:short_url].metadata || {} %>
<% title = metadata["og_title"].presence || metadata["title"].presence || local_assigns[:short_url].target_url %>
<% description = metadata["description"].presence || "" %>
<% og_image = metadata["og_image"].presence %>

<% content_for :title, title %>

<% content_for :head do %>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="noindex">

  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <% if og_image.present? %>
    <meta property="og:image" content="<%= og_image %>">
  <% end %>

  <meta name="twitter:card" content="<%= og_image.present? ? "summary_large_image" : "summary" %>">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">
  <% if og_image.present? %>
    <meta name="twitter:image" content="<%= og_image %>">
  <% end %>
  <meta http-equiv="refresh" content="0;url=<%= local_assigns[:short_url].target_url %>">
<% end %>

<div class="space-y-4 text-center py-16">
  <p class="text-slate-500 text-sm">Redirecting you to</p>
  <p class="font-bold text-lg break-all"><%= local_assigns[:short_url].target_url %></p>
  <p class="text-slate-400 text-sm">
    If you are not redirected, <a href="<%= local_assigns[:short_url].target_url %>" class="underline text-blue-500">click here</a>.
  </p>
</div>
